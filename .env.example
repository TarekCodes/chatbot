# ── LLM provider ──────────────────────────────────────────────────────────────
# Set to "anthropic" or "openai"
LLM_PROVIDER=anthropic

# ── Anthropic (used when LLM_PROVIDER=anthropic) ──────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI (used when LLM_PROVIDER=openai) ────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Admin ──────────────────────────────────────────────────────────────────────
ADMIN_KEY=choose-a-secret-key

# ── Bot behaviour ──────────────────────────────────────────────────────────────
SYSTEM_PROMPT=You are a helpful assistant for [Your Business]. Answer questions based on the provided context. If the answer is not found in the context, say so honestly.
